import pandas as pd

df = pd.read_csv("DS440 recent headlines.csv")

sanjana_clean = pd.DataFrame({
    "source": df["postText_clean"],          # CNN, NYT, etc.
    "headline": df["targetTitle_clean"],     # article title
    "description": df["targetDescription"],  # summary
    "published": None                        # no date available
})

sanjana_clean.to_csv("sanjana_cleaned.csv", index=False)

print(sanjana_clean.head())